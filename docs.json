{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Kylon",
  "theme": "maple",
  "colors": {
    "primary": "#045C45",
    "light": "#12A594",
    "dark": "#19DBC4"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
  "font": {
    "headings": {
      "family": "Inter",
      "weight": 600
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "rounded": "default",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "quickstart",
              "authentication",
              "concepts"
            ]
          },
          {
            "group": "CLI",
            "pages": [
              "cli/overview",
              "cli/installation",
              "cli/auth",
              "cli/gateway",
              "cli/gateway-run",
              "cli/agent",
              "cli/workspace",
              "cli/secrets",
              "cli/providers",
              "cli/troubleshooting"
            ]
          },
          {
            "group": "Proxy",
            "pages": [
              "proxy/overview",
              "proxy/authentication",
              "proxy/tools-api",
              "proxy/app-connections",
              "proxy/model-apis",
              "proxy/provider-apis",
              "proxy/billing",
              "proxy/errors"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Connections",
            "pages": [
              "api-reference/list-connections",
              "api-reference/get-auth-url"
            ]
          },
          {
            "group": "Toolkits",
            "pages": [
              "api-reference/search-toolkits",
              "api-reference/get-toolkit-details",
              "api-reference/search-toolkit-tools"
            ]
          },
          {
            "group": "Execution",
            "pages": [
              "api-reference/execute-tool",
              "api-reference/proxy-request",
              "api-reference/upload-file"
            ]
          }
        ]
      }
    ]
  },
  "api": {
    "baseUrl": "https://api.kylon.io",
    "auth": {
      "method": "key",
      "name": "x-api-key"
    },
    "playground": {
      "mode": "simple"
    }
  },
  "openapi": "openapi.json",
  "topbarLinks": [
    {
      "name": "Support",
      "url": "mailto:support@kylon.io"
    }
  ],
  "topbarCtaButton": {
    "name": "Dashboard",
    "url": "https://app.kylon.io"
  },
  "seo": {
    "metatags": {
      "canonical": "https://docs.kylon.io",
      "description": "Kylon developer documentation: CLI gateway, workspace CLI, proxy APIs for tools, models, and data providers. Build agents that work with Kylon workspaces.",
      "og:title": "Kylon Developer Docs",
      "og:description": "Build agents that work with Kylon workspaces. CLI gateway, workspace CLI, proxy APIs for tools, models, and data providers.",
      "og:image": "https://docs.kylon.io/logo/dark.svg",
      "og:type": "website",
      "twitter:card": "summary",
      "twitter:title": "Kylon Developer Docs",
      "twitter:description": "CLI gateway, workspace CLI, and proxy APIs for building agents on Kylon."
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/kylon_ai",
      "github": "https://github.com/fre-so"
    }
  }
}
